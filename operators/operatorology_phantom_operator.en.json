  "phantom_operator": {
    "id": "O_PHANTOM",
    "name": "Phantom Operator (𝒪_phantom)",
    "definition": {
      "unicode": "𝒪_phantom = B⁻¹ ∘ A⁻¹ ∘ B ∘ A",
      "ascii": "O_phantom = B^-1 o A^-1 o B o A",
      "pattern": "act–shift–withdraw–restore (commutator form)"
    },
    "interpretation": [
      "Self approximate invariance: state returns near baseline after A,B,A^-1,B^-1.",
      "Opponent/disturbance phase error: due to latency/inertia, the response targets a withdrawn cue."
    ],
    "phase_error": {
      "epsilon_tau": "ε_τ = τ_expected − τ_actual",
      "epsilon_psi": "ε_ψ = ψ_allocated − ψ_effective"
    }
  },
  "operator_basis": {
    "combat": {
      "A": {
        "id": "A_FEINT_CUE_COMBAT",
        "role": "High-salience feint cue (targets ψ_opp, τ_opp)",
        "update_summary": [
          "psi' = clamp01(psi - kPsi*dt)",
          "tau' = tau + kTau*dt"
        ],
        "inverse_summary": [
          "psi' = clamp01(psi + rollbackPsi*dt)",
          "tau' = max(0, tau - rollbackTau*dt)"
        ]
      },
      "B": {
        "id": "B_MICRO_SHIFT_COMBAT",
        "role": "Micro shift / axis change (targets x, v, theta; erodes S)",
        "update_summary": [
          "x' = x + [dPos*dt, 0]",
          "v' = R(dTheta*dt) v",
          "theta' = theta + dTheta*dt",
          "S' = clamp01(S - kS*dt)"
        ],
        "inverse_summary": [
          "x' = x - [dPos*dt, 0]",
          "v' = R(-dTheta*dt) v",
          "theta' = theta - dTheta*dt",
          "S' = clamp01(S + restoreS*dt)"
        ]
      }
    },
    "silicon": {
      "A": {
        "id": "A_SCHEDULER_PULSE_SILICON",
        "role": "Scheduler/gain pulse (catch disturbance) using telemetry",
        "update_summary": [
          "a' = clamp01(a + da*dt)",
          "q' = max(0, q + dq*dt)",
          "s' = clamp01(s + ds*dt)"
        ],
        "inverse_summary": [
          "withdraw pulse toward baseline; partial rollback due to inertia"
        ]
      },
      "B": {
        "id": "B_PROFILE_SHIFT_SILICON",
        "role": "DVFS/mapping/NoC micro-profile shift (morphological control)",
        "update_summary": [
          "f' = max(0, f + df*dt)",
          "kappa' = kappaNext",
          "q' = max(0, q + dq*dt)",
          "s' = clamp01(s + ds*dt)"
        ],
        "inverse_summary": [
          "restore toward base profile (kappaRestore)"
        ]
      }
    }
  },
  "thin_isa": {
    "cmd_format": "CMD = (OPCODE, TILE_MASK, PARAM, DURATION, SAFETY_TAG)",
    "phantom_packaging": "O_phantom = [A, B, A^-1, B^-1]",
    "safety_override": "If T>T_max or P>P_max or s<s_critical => force dampen/cooldown operator."
  },
