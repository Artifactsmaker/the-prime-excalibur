  "source_lineage": {
    "derived_from_user_text": true,
    "core_claims": [
      "Latency/inertia create phase errors when a cue is withdrawn before an opponent can update.",
      "Approximate invariance for self can be achieved via act–shift–withdraw–restore structure.",
      "On silicon, Phantom maps to telemetry-driven reconfiguration (DVFS/NoC/mapping) with safety supervision."
    ]
  },
  "axioms": [
    {
      "id": "A1",
      "name": "Cognitive Latency",
      "statement": "Micro-changes affecting an opponent's awareness/decision state require non-zero latency τ > 0 before a reaction vector is formed."
    },
    {
      "id": "A2",
      "name": "State Inertia",
      "statement": "Once a reaction is committed, it cannot be revoked instantly; there exists an inertia delay Δt_inertia."
    },
    {
      "id": "A3",
      "name": "Action as State Transformation",
      "statement": "There is no free-standing 'command'; only operators 𝒪: state → state′."
    },
    {
      "id": "A4",
      "name": "Stability Priority (Silicon)",
      "statement": "There exists a stability index s = S(Σ) with a hard constraint s ≥ s_critical under operation."
    }
  ],
