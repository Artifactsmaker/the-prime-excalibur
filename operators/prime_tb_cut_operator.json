{
  "id": "omega_prime_tb_cut",
  "symbol": "ΩPTB",
  "name": "Prime-TB Cut Operator",
  "short_name": "Prime-TB Cut",
  "category": "prime_guided_topological_boundary_decomposition",
  "version": "1.0",
  "status": "conceptual_reference",
  "description": "A reusable prime-guided topological-boundary operator that decomposes a structured entity into prime identity, boundary, shadow, spectral, interface, and recomposable layers.",
  "formal_definition": {
    "operator": "Ω_PTB(E) = Cut(E | PGS(E), TB(E), θ)",
    "cut_site": "CutSite(E) = { x in E | PAM(x) = true and TB_score(x) >= θ }",
    "output": "Ω_PTB(E) -> { I_P, B_T, S_D, Q_S, G_I, R_C }"
  },
  "conceptual_analogy": {
    "crispr_cas9": {
      "substrate": "DNA",
      "guide": "guide RNA",
      "recognition_motif": "PAM",
      "cutting_agent": "Cas9",
      "cut_site": "DNA cut site",
      "post_cut_process": "repair or recombination"
    },
    "prime_tb_cut": {
      "substrate": "represented entity E",
      "guide": "PGS(E): Prime Guide Signature",
      "recognition_motif": "PAM: Prime Alignment Motif",
      "cutting_agent": "Ω_PTB",
      "cut_site": "Prime Cut Site",
      "post_cut_process": "atlas recomposition"
    }
  },
  "inputs": [
    "entity",
    "entity_class",
    "numeric_identity",
    "topological_boundaries",
    "metadata"
  ],
  "outputs": [
    "prime_guide_signature",
    "prime_alignment_motifs",
    "prime_cut_sites",
    "decomposed_layers",
    "recomposition_note"
  ],
  "core_components": {
    "PGS": {
      "name": "Prime Guide Signature",
      "role": "The guide signature that directs Ω_PTB toward prime-readable identity boundaries.",
      "possible_descriptors": [
        "prime_factorization",
        "prime_count",
        "distinct_prime_count",
        "factor_entropy",
        "prime_overlap",
        "prime_gap",
        "radical_signature",
        "prime_power_status",
        "gcd_signature",
        "lcm_signature"
      ]
    },
    "PAM": {
      "name": "Prime Alignment Motif",
      "role": "A prime-structured motif indicating that a component or layer is eligible for a Prime-TB Cut.",
      "rule": "No PAM, no cut."
    },
    "TB": {
      "name": "Topological Boundary Profile",
      "role": "A profile of structural boundaries where an entity changes representational layer."
    }
  },
  "layers": [
    {
      "symbol": "I_P",
      "name": "Prime Identity",
      "description": "Prime-number identity layer extracted from countable or identity-bearing variables."
    },
    {
      "symbol": "B_T",
      "name": "Topological Boundary",
      "description": "Structural boundary layer where the entity shifts representational mode."
    },
    {
      "symbol": "S_D",
      "name": "Shadow Decomposition",
      "description": "Relational or decay-shadow layer."
    },
    {
      "symbol": "Q_S",
      "name": "Spectral Signature",
      "description": "Spectral expression or lightprint descriptor layer."
    },
    {
      "symbol": "G_I",
      "name": "Interface Geometry",
      "description": "Interface or interaction geometry layer, including bioinorganic surfaces."
    },
    {
      "symbol": "R_C",
      "name": "Recomposable Core",
      "description": "Recomposition-ready core representation for atlas, benchmark, or AI workflows."
    }
  ],
  "boundary_types": [
