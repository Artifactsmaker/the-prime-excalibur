    "upgradePurpose": "Convert ECO from research specification into executable runtime with candidate profiling, entropy estimation, mode selection, collapse application, adaptive thresholding, safety guards, trace, demo, and self-tests."
  },
  "runtimeClassification": {
    "operatorClass": "meta_operator",
    "runtimeClass": "admissibility_collapse_runtime",
    "isDerivedFromFixedPointLaw": true,
    "parentLaw": "U(x)=x",
    "modes": [
      "OPEN",
      "BOUND",
      "COLLAPSE",
      "ADAPT"
    ]
  },
  "coreSemantics": {
    "objective": "Reduce the active possibility space by retaining states with higher admissibility to a fixed-point basin approximation.",
    "entropyReading": "Operational entropy is interpreted as risk mass / distance from structural and fixed-point stability, not mere randomness.",
    "admissibilityCriterion": "A state remains active when its weighted admissibility score and fixed-point proximity are sufficient under the current mode and thresholds.",
    "safetyPrinciple": "Collapse is forbidden when confidence is too low, the domain metric is incompatible, or the active space would fall below minimum viable support."
  },
  "runtimeExports": [
    "runECO",
    "runECOBatch",
    "profileCandidate",
    "profileSpace",
    "selectCollapseMode",
    "applyCollapse",
    "adaptThresholds",
    "normalizedOperationalEntropy",
    "demoECO",
    "runSelfTests"
  ],
  "dataModel": {
    "candidate": [
      "id",
      "payload?",
      "viability?",
      "support?",
      "confidence?",
      "metrics?",
      "tags?"
    ],
    "metrics": [
      "structuralComplexity",
      "fixedPointError",
      "semanticDispersion",
      "branchingFactor",
      "curvature",
      "instability",
      "inconsistency"
    ],
    "thresholds": [
      "structuralThreshold",
      "entropyThreshold",
      "fixedPointTolerance",
      "semanticDispersionThreshold",
      "maxBranchingFactor",
      "minCollapseConfidence",
      "minViableCardinality",
      "boundScoreFloor",
      "collapseScoreFloor",
      "boundKeepRatio",
      "collapseKeepRatio",
      "adaptRate"
    ],
    "output": [
      "mode",
      "requestedMode",
      "profileBefore",
      "profileAfter",
      "deltaEntropy",
      "branchReduction",
      "kept",
      "rejected",
      "recoveryBuffer",
      "activeMask",
      "safetyEvents",
      "trace"
    ]
  },
  "pipeline": [
    {
      "step": 1,
      "id": "measure_structure",
      "runtime": "profileCandidate + profileSpace"
    },
    {
      "step": 2,
      "id": "estimate_entropy",
      "runtime": "normalizedOperationalEntropy over risk mass"
    },
    {
      "step": 3,
      "id": "select_mode",
      "runtime": "selectCollapseMode"
    },
    {
      "step": 4,
      "id": "apply_collapse",
      "runtime": "applyCollapse with OPEN/BOUND/COLLAPSE/ADAPT"
    },
    {
      "step": 5,
      "id": "safety_guard",
      "runtime": "domain_mismatch, no_premature_collapse, overcompression"
    },
    {
      "step": 6,
      "id": "emit_trace",
      "runtime": "ECOTraceStep[] + activeMask + recoveryBuffer"
    }
  ],
  "defaultThresholds": {
    "structuralThreshold": 1,
